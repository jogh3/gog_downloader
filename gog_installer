#!/usr/bin/env bash

type curl > /dev/null 2>&1
if [[ $? -eq 1 ]]; then
  echo "curl not installed"
  exit 1
fi
type jq > /dev/null 2>&1
if [[ $? -eq 1 ]]; then
  echo "jq not installed"
  exit 1
fi
readonly config_dir="$HOME/.config/gog_downloader"
readonly config_file="$config_dir/config.json"
readonly gog_api_prefix="https://api.gog.com"
dllocfolder=""
mkdir -p "$config_dir"
max_cores=0
game=""
login_code=""
get_num_cores() {
  read -r online_str < /sys/devices/system/cpu/online
  IFS=',' read -ra elements <<< "$online_str"

  for item in "${elements[@]}"; do
      if [[ "$item" =~ - ]]; then
          IFS='-' read -r start end <<< "$item"
          (( max_cores += end - start + 1 ))
      else
          (( max_cores++ ))
      fi
  done
  (( max_cores -- ))
}

parse_args(){

  local help_message="
  gog_installer - downloads executables from gog
  
    --set-download-location DIRECTORY_LOCATION sets the location where the mods will download to
    --help -h displays this message
    --game -g GAME the game you want to download
  "

  while [[ "$#" -gt 0 ]]; do
    case $1 in
      -h|--help)
        echo "$help_message"
        exit 0
        ;;
      --set-download-location)
        if [[ -z "$2" ]] || [[ "$2" =~ ^- ]]; then
          echo "no download location specified"
          exit 1
        fi
        
        if [[ "$2" == "~"* ]]; then
          dllocfolder="${2/#\~/$HOME}"
        elif [[ "$2" == "default" ]]; then
          dllocfolder="$HOME/Documents/gog_games"
        else
          dllocfolder=$2
        fi
        dllocfolder=$(realpath -m "$dllocfolder")
        dllocfolder="${dllocfolder%/}"
        shift 2
        ;;
      --game | -g)
        shift 2
        ;;
      *)
        echo "unknow argument: $1"
        echo "$help_message"
        exit 1
        ;;
    esac
  done
}

get_authentication(){
  echo "open: https://auth.gog.com/auth?client_id=46899977096215655&redirect_uri=https%3A%2F%2Fembed.gog.com%2Fon_login_success%3Forigin%3Dclient&response_type=code&layout=client2"
  local redirect_url
  read -rp "paste the full redirect url here: " redirect_url
  login_code=$(echo "$redirect_url" | grep -oP 'code=\K[^&]+')
}

get_game_list() {
  local game_list_url="${gog_api_prefix}/account/getFilteredProducts?sortBy"
  game_list=$(curl -H "Authorization: Bearer $login_code" $game_list_url)
}

main() {
  parse_args $@
  get_num_cores
  echo "max cores available: $max_cores"
  if [[ ! -f $config_file ]]; then
    echo '{"dllocfolder":"","authentication":""}' > $config_file
  fi
  if [[ -z "$dllocfolder" ]]; then
    dllocfolder="$(jq '.dllocfolder' "$config_file")"
  else
    jq --arg folder "$dllocfolder" '.dllocfolder = $folder' "$config_file" > /tmp/tmp.json && mv /tmp/tmp.json "$config_file"
  fi
  if jq -e '.authentication' "$config_file" >/dev/null; then
    get_authentication
    if [[ ! -z $login_code ]]; then
      echo "writing auth code to file"
      jq --arg auth_code "$login_code" '.authentication = $auth_code' "$config_file" > /tmp/tmp.json && mv /tmp/tmp.json "$config_file"
    fi
  fi
  # get_game_list
  return 0
}

main $@
